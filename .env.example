# Transport Configuration
# Choose "stdio" for desktop/CLI integration or "http" for remote/containerized deployment
TRANSPORT_MODE=stdio
# Port for HTTP mode (ignored in stdio mode)
HTTP_PORT=3000

# API Integration
# Get your free API key from: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
# Timeout for weather API requests in milliseconds
WEATHER_API_TIMEOUT=5000

# Security Configuration
# Colon-separated list of safe directories for file:// resource access
# Example: /tmp:/home/user/safe:/var/data
ALLOWED_FILE_PATHS=/tmp

# Comma-separated list of valid API keys for HTTP authentication
# Generate secure keys with: openssl rand -base64 32
API_KEYS=demo_key_1,demo_key_2

# Maximum requests per minute per client (HTTP transport only)
RATE_LIMIT_REQUESTS=60

# Observability Configuration
# Log level: "debug", "info", "warn", "error"
LOG_LEVEL=info

# Log format: "json" for production, "pretty" for development
LOG_FORMAT=pretty

# Caching Configuration
# Weather data cache TTL in seconds (600 = 10 minutes)
WEATHER_CACHE_TTL=600

# CORS Configuration
# Restrict to specific origins in production (e.g., https://yourapp.com)
# Defaults to '*' (all origins) in development
# CORS_ORIGIN=https://yourapp.com

# Application Configuration
# Node environment: "development", "production", "test"
NODE_ENV=development
